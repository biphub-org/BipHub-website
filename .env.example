# =============================================================================
# BipHub — .env.example
#
# PLACEHOLDER VALUES ONLY. Never commit real secrets to this file.
# gitleaks scans every PR; a real secret here will block the merge.
#
# Local development setup:
#   1. Copy this file: `cp .env.example .env.local`
#   2. `supabase start`
#   3. `npx supabase status` — copy the printed keys into .env.local:
#        - anon key       → NEXT_PUBLIC_SUPABASE_ANON_KEY
#        - service_role   → SUPABASE_SERVICE_ROLE_KEY
#      Supabase CLI ≥ 2.98 emits `sb_publishable_*` / `sb_secret_*` keys —
#      re-pull from `supabase status` after every `supabase start`.
#   4. Leave RESEND_API_KEY blank in local dev — lib/email/send.ts falls back
#      to console.log when unset (D-15 from Phase 3 + Phase 4).
#
# CI / E2E:
#   The Playwright workflow in .github/workflows/e2e.yml boots a fresh
#   Supabase instance per job; it reads keys from `supabase status` at
#   runtime, never from environment secrets in GitHub Actions.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-status

# Phase 2 — required for auth callback emailRedirectTo and password reset redirectTo
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase 3 — Resend transactional email (ADMN-09, ADMN-10, ADMN-11).
# Leave RESEND_API_KEY blank in local dev — `lib/email/send.ts` falls back
# to console.log of the rendered HTML when the key is unset (D-15).
RESEND_API_KEY=

# Phase 3 — Admin recipient for new-submission notifications (ADMN-11).
# Single admin address that receives AdminNotificationEmail when a coordinator
# submits a BIP for review. When unset, submitBipAction logs a warning but the
# submission itself still succeeds (D-11 fire-and-forget).
ADMIN_NOTIFICATION_EMAIL=

# Optional reply-to override for transactional emails (defaults to noreply@biphub.eu).
ADMIN_REPLY_TO_EMAIL=
